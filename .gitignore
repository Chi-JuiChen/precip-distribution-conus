# =============================================================================
# Git ignore — precip-distribution-conus
# =============================================================================

# ── Credentials & secrets (never commit these) ────────────────────────────
.env
.env.*
*.pem
*.key
*.p12
netrc
.netrc
secrets.yaml
secrets.yml
credentials.json

# ── Large data files ──────────────────────────────────────────────────────
# Raw inputs: CPC (~200 MB) and IMERG (~214 GB) — download via scripts
data/raw/
# Processed NetCDF arrays (~1.4 GB) — regenerated by preprocess.py
data/processed/

# ── Pipeline outputs (binary, regeneratable) ─────────────────────────────
output/unconditional/stats/
output/conditional/stats/

# ── Python cache ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Jupyter ───────────────────────────────────────────────────────────────
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# ── macOS ─────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride

# ── IDE / editor ──────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

# ── Claude Code (local session settings) ─────────────────────────────────
.claude/

# ── Conda / virtual environments ─────────────────────────────────────────
.conda/
env/
venv/
.venv/
